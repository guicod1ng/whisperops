generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id         Int          @id @default(autoincrement())
  nome       String
  email      String       @unique
  senha      String
  criado_em  DateTime     @default(now())
  atendentes Atendente[]
  conversas  Conversa[]
}

model Atendente {
  id         Int         @id @default(autoincrement())
  nome       String
  empresa_id Int
  empresa    Empresa     @relation(fields: [empresa_id], references: [id])
  conversas  Conversa[]
}

model Conversa {
  id            Int         @id @default(autoincrement())
  cliente_nome  String
  cliente_fone  String
  atendente_id  Int
  empresa_id    Int
  status        String      @default("analisada")
  data_import   DateTime    @default(now())
  atendente     Atendente   @relation(fields: [atendente_id], references: [id])
  empresa       Empresa     @relation(fields: [empresa_id], references: [id])
  mensagens     Mensagem[]
  metrica       Metrica?
}

model Mensagem {
  id          Int      @id @default(autoincrement())
  conversa_id Int
  remetente   String
  texto       String
  data_hora   DateTime
  conversa    Conversa @relation(fields: [conversa_id], references: [id])
}

model Metrica {
  id               Int      @id @default(autoincrement())
  conversa_id      Int      @unique
  tempo_resposta   Int
  palavras_chave   String
  sentimento       String
  score            Float
  resumo_ia        String
  conversa         Conversa @relation(fields: [conversa_id], references: [id])
}